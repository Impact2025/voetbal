# Kopieer naar .env.local — vul alle waarden in voor lokale dev
# .env.local staat in .gitignore en wordt nooit gecommit
# Productie-waarden zet je in Vercel dashboard

# ─── Supabase ────────────────────────────────────────────────────────────
# Project Settings > API
VITE_SUPABASE_URL=https://jouw-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Server-side only (Vercel env vars — NIET in .env.local voor dev)
# SUPABASE_URL=https://jouw-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Stripe ─────────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PRICE_ID=price_...
# STRIPE_SUCCESS_URL=https://skillkaart.nl/?upgrade=success
# STRIPE_CANCEL_URL=https://skillkaart.nl/?upgrade=cancel
# STRIPE_WEBHOOK_TOKEN=...

# ─── Email (Resend) ─────────────────────────────────────────────────────
# RESEND_API_KEY=re_...
# MAIL_FROM='Skillkaart <verzending@skillkaart.nl>'
# UNSUBSCRIBE_SECRET=...

# ─── AI Blog (OpenRouter) ───────────────────────────────────────────────
# OPENROUTER_API_KEY=sk-or-...
# BLOG_AI_MODEL=google/gemini-2.5-flash

# ─── Error monitoring (optioneel) ───────────────────────────────────────
# SENTRY_DSN=https://xxx@xxx.ingest.us.sentry.io/xxxxx

# ─── Overig ─────────────────────────────────────────────────────────────
# PUBLIC_BASE_URL=https://skillkaart.nl (voor SSR canonical URLs)
# CRON_SECRET=... (Vercel Cron authorization)

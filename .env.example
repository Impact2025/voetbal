# Kopieer naar .env.local — vul alle waarden in voor lokale dev
# .env.local staat in .gitignore en wordt nooit gecommit
# Productie-waarden zet je in Vercel dashboard

# ─── Supabase ────────────────────────────────────────────────────────────
# Project Settings > API
VITE_SUPABASE_URL=https://jouw-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Server-side only (Vercel env vars — NIET in .env.local voor dev)
# SUPABASE_URL=https://jouw-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Stripe ─────────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PRICE_ID=price_...
# STRIPE_SUCCESS_URL=https://skillkaart.nl/?upgrade=success
# STRIPE_CANCEL_URL=https://skillkaart.nl/?upgrade=cancel
# STRIPE_WEBHOOK_TOKEN=...

# ─── Email (Resend) ─────────────────────────────────────────────────────
# RESEND_API_KEY=re_...
# MAIL_FROM='Skillkaart <verzending@skillkaart.nl>'
# UNSUBSCRIBE_SECRET=...

# ─── AI (OpenRouter) — SERVER-SIDE ──────────────────────────────────────
# Server-side key voor /api/ai (speler/coach-feedback + videoanalyse) én de blog.
# NOOIT als VITE_ — dan lekt hij in de browser-bundle. De oude
# VITE_OPENROUTER_API_KEY is vervangen door deze en kan verwijderd worden.
# OPENROUTER_API_KEY=sk-or-...
# AI_MODEL=google/gemini-2.5-flash        # standaardmodel voor /api/ai
# BLOG_AI_MODEL=google/gemini-2.5-flash   # apart model voor blog-generatie

# ─── Error monitoring (optioneel) ───────────────────────────────────────
# SENTRY_DSN=https://xxx@xxx.ingest.us.sentry.io/xxxxx

# ─── VAPID keys (Web Push — spelers) ─────────────────────────────────────
# Public key mag in VITE_ (zichtbaar in de browser).
# Private key alleen server-side — zet in Vercel env vars, NIET in frontend.
# VITE_VAPID_PUBLIC_KEY=BCau8OUNeTpcElntf7v8Um1ToHqUaVcMJ8Fj5dgBhNRrHk3NPR61V2JKgvIcSE4ZwRvGTwn4ZphyqM4r-l7NzWg

# ─── VAPID keys (Web Push — ouders) ──────────────────────────────────────
# Eigen sleutelpaar, los van de spelers-key hierboven (voorkomt dat een
# sleutelwissel de al werkende speler-push breekt). Gebruikt door
# api/cron/notify-parents.ts en usePWA.ts's subscribeParentPush.
# VITE_PARENT_VAPID_PUBLIC_KEY=...
# Server-side only (Vercel env vars):
# VAPID_PUBLIC_KEY=...  (zelfde waarde als VITE_PARENT_VAPID_PUBLIC_KEY)
# VAPID_PRIVATE_KEY=...
# VAPID_EMAIL=hello@skillkaart.nl

# ─── Overig ─────────────────────────────────────────────────────────────
# PUBLIC_BASE_URL=https://skillkaart.nl (voor SSR canonical URLs)
# CRON_SECRET=... (Vercel Cron authorization)
